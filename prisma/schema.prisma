// Prisma tooling — Studio, db pull, introspection
//
// Database: VPS PostgreSQL (DATABASE_URL) — NOT Prisma hosted cloud
// Authoritative DDL: database/schema/ (npm run db:setup / db:migrate)
// App runtime: `pg` + SQL (not Prisma Client)
//
// After schema changes:
//   npm run db:prisma:pull   → refresh this file from live DB
//   npm run db:studio        → open Prisma Studio

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

// Models are generated by: npm run db:prisma:pull
