# =============================================================================
# LOCAL DEV — copy to project root as .env.local
# Monorepo: 3 portals on different ports
# =============================================================================

NODE_ENV=development

# --- 3 portal URLs (localhost) ---
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_OPERATOR_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Per-portal auth URLs (required for login cookies)
AUTH_OPERATOR_URL=http://localhost:3002
AUTH_ADMIN_URL=http://localhost:3001
AUTH_URL=http://localhost:3002
NEXTAUTH_URL=http://localhost:3002
AUTH_COOKIE_SECURE=false

# Database — Prisma hosted Postgres (cloud). Copy connection string from prisma.io dashboard.
# Do NOT use localhost unless you explicitly run: npm run db:prisma:start
DATABASE_URL=postgres://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require
DATABASE_POOL_MAX=3

# Auth — openssl rand -hex 32
AUTH_SECRET=your-super-secret-key-min-32-characters-change-this-later-12345678
NEXTAUTH_SECRET=your-super-secret-key-min-32-characters-change-this-later-12345678
SUPER_ADMIN_SECURITY_CODE=CYBER-LINK-2026

# Syslog listener (optional — npm run syslog:listener)
SYSLOG_UDP_PORT=5514
SOCKET_PORT=3003
NEXT_PUBLIC_SOCKET_URL=http://localhost:3003
INGEST_SECRET=local-dev-secret-123
DEFAULT_TENANT_SCHEMA=tenant_001

# Optional
IMGBB_API_KEY=
CRON_SECRET=local-cron-secret

# BTRC
BTRC_ISP_LICENSE=ISP-BD-CYBER-2024
BTRC_ISP_NAME=Cyber Link Communication
BTRC_CONTACT_EMAIL=admin@cyberlink.com
