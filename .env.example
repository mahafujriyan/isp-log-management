# Database Connection
DATABASE_URL=postgresql://loguser:StrongPassword123!@localhost:5432/isp_logserver

# NextAuth / Auth.js (PHASE 5)
AUTH_SECRET=your-super-secret-key-min-32-characters-change-this-later-12345678
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-min-32-characters-change-this-later-12345678
NEXTAUTH_URL=http://localhost:3000

# Super Admin Security (required for /auth/super-admin portal)
SUPER_ADMIN_SECURITY_CODE=CYBER-LINK-2026

# BTRC Integration (Bangladesh regulatory compliance)
BTRC_ISP_LICENSE=ISP-BD-CYBER-2024
BTRC_ISP_NAME=Cyber Link Communication
BTRC_API_URL=
BTRC_API_KEY=
BTRC_AUTO_SUBMIT=false
BTRC_SUBMIT_INTERVAL_HOURS=24
BTRC_RETENTION_DAYS=180
BTRC_CONTACT_EMAIL=admin@cyberlink.com
CRON_SECRET=change-this-for-scheduled-btrc-submit
INGEST_SECRET=change-this-for-syslog-ingest-api

# MikroTik Syslog Listener (PM2: isp-syslog-listener)
# Use 5514 on Windows/local dev (514 needs admin)
SYSLOG_UDP_PORT=5514
SOCKET_PORT=3001
SYSLOG_FILE=/var/log/mikrotik/isp-syslog.log
DEFAULT_TENANT_SCHEMA=tenant_001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ImageBB — company logo hosting (https://api.imgbb.com)
IMGBB_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
