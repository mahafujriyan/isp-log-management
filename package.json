{
  "name": "isp-log-management",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:open": "node scripts/open-dev-urls.mjs",
    "dev:check": "node scripts/dev-check.mjs",
    "dev:stop": "node scripts/kill-dev-ports.mjs",
    "dev:sync-env": "node scripts/sync-env.mjs",
    "dev:marketing": "npm run dev -w @isp/marketing",
    "dev:admin": "npm run dev -w @isp/super-admin",
    "dev:operator": "npm run dev -w @isp/operator",
    "build": "npm run build:operator",
    "build:all": "npm run build -w @isp/marketing && npm run build -w @isp/super-admin && npm run build -w @isp/operator",
    "build:marketing": "npm run build -w @isp/marketing",
    "build:admin": "npm run build -w @isp/super-admin",
    "build:operator": "npm run build -w @isp/operator",
    "start:marketing": "npm run start -w @isp/marketing",
    "start:admin": "npm run start -w @isp/super-admin",
    "start:operator": "npm run start -w @isp/operator",
    "lint": "eslint apps/marketing/src apps/super-admin/src apps/operator/src packages workers",
    "type-check": "npm run type-check -w @isp/core --if-present && npm run type-check -w @isp/operator --if-present",
    "migrate:monorepo": "node scripts/migrate-monorepo.mjs",
    "verify:phase1": "node scripts/verify-phase1.mjs",
    "verify:phase2": "node scripts/verify-phase2.mjs",
    "verify:phase3": "node scripts/verify-phase3.mjs",
    "verify:phase4": "node scripts/verify-phase4.mjs",
    "verify:phase5": "node scripts/verify-phase5.mjs",
    "verify:phase6": "node scripts/verify-phase6.mjs",
    "verify:phase7": "node scripts/verify-phase7.mjs",
    "verify:phase8": "node scripts/verify-phase8.mjs",
    "verify:phase9": "node scripts/verify-phase9.mjs",
    "verify:all": "node scripts/verify-phase1.mjs && node scripts/verify-phase2.mjs && node scripts/verify-phase3.mjs && node scripts/verify-phase4.mjs && node scripts/verify-phase5.mjs && node scripts/verify-phase6.mjs && node scripts/verify-phase7.mjs",
    "pm2:start": "pm2 start deploy/ecosystem.config.cjs",
    "pm2:stop": "pm2 stop deploy/ecosystem.config.cjs",
    "pm2:restart": "pm2 restart deploy/ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "test:log-ingest": "node scripts/test-log-ingest.mjs",
    "db:vps": "node scripts/apply-all-migrations.mjs",
    "db:migrate": "node scripts/apply-all-migrations.mjs",
    "db:device-credentials": "node scripts/apply-device-credentials.mjs",
    "db:init": "cd scripts && psql -U loguser -d isp_logserver -f init-db.sql",
    "db:setup": "node scripts/setup-database.mjs",
    "db:demo": "node scripts/apply-demo-migrations.mjs",
    "db:company-branding": "node scripts/apply-company-branding.mjs",
    "db:syslog": "node scripts/apply-mikrotik-syslog.mjs",
    "db:register-sfp1": "node scripts/apply-register-sfp1.mjs",
    "db:sync-routers": "node scripts/sync-router-map.mjs",
    "syslog:listener": "npm run start -w @isp/syslog-listener",
    "db:phase2": "cd scripts && psql -U loguser -d isp_logserver -f phase2-migration.sql",
    "db:phase8": "cd scripts && psql -U loguser -d isp_logserver -f phase8-migration.sql"
  },
  "dependencies": {
    "aos": "^2.3.4",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.21.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "syslog-server": "^1.0.1",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/aos": "^3.0.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "turbo": "^2.5.4",
    "concurrently": "^9.2.0"
  }
}
