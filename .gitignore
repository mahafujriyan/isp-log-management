# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js (root + all apps in monorepo) ---
.next/
out/
apps/*/.next/
apps/*/out/

# --- build / cache ---
build/
dist/
.turbo/
*.tsbuildinfo

# --- testing ---
coverage/

# --- env & secrets (never commit) ---
.env
.env.*
!.env.example
!.env*.example
.env.local
.env.production.local
.db-credentials
.env.development.local
.env.test.local
apps/*/.env.local

# --- logs & debug ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/logs/
*.log.*

# --- PM2 ---
.pm2/
pids/
*.pid

# --- OS / editor ---
.DS_Store
Thumbs.db
Desktop.ini
*.pem
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# --- deploy / hosting ---
.vercel
.netlify

# --- TypeScript (generated per app) ---
next-env.d.ts
apps/*/next-env.d.ts

# --- misc temp ---
*.swp
*.swo
*~
.cache/
tmp/
temp/

# --- optional local overrides ---
*.local.json

/src/generated/prisma
