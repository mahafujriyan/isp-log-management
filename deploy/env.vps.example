# =============================================================================
# VPS PRODUCTION — copy to project root as .env.production.local
# Server: 160.187.175.30 | MikroTik: 160.187.175.26
# Guide: deploy/VPS-HOSTING.md (PART 4 = env, PART 10 = domain)
# Domain sheet: deploy/domains.template.env → deploy/domains.env
# =============================================================================

NODE_ENV=production

# --- PHASE A: IP + Port (deploy now) ---
NEXT_PUBLIC_MARKETING_URL=http://160.187.175.30:3000
NEXT_PUBLIC_ADMIN_URL=http://160.187.175.30:3001
NEXT_PUBLIC_OPERATOR_URL=http://160.187.175.30:3002
NEXT_PUBLIC_API_URL=http://160.187.175.30:3002

# --- PHASE B: Domain (uncomment when PART 10 done) ---
# NEXT_PUBLIC_MARKETING_URL=https://www.YOUR-DOMAIN.com
# NEXT_PUBLIC_ADMIN_URL=https://admin.YOUR-DOMAIN.com
# NEXT_PUBLIC_OPERATOR_URL=https://app.YOUR-DOMAIN.com
# NEXT_PUBLIC_API_URL=https://app.YOUR-DOMAIN.com

# Legacy single-app vars (operator app)
NEXT_PUBLIC_APP_URL=http://160.187.175.30:3002
AUTH_OPERATOR_URL=http://160.187.175.30:3002
AUTH_ADMIN_URL=http://160.187.175.30:3001
AUTH_URL=http://160.187.175.30:3002
NEXTAUTH_URL=http://160.187.175.30:3002

# HTTP VPS without SSL — required for login/logout on IP address
AUTH_COOKIE_SECURE=false

# Socket.IO — same origin as operator when nginx proxies /socket.io → 3001
NEXT_PUBLIC_SOCKET_URL=http://160.187.175.30:3002

# PM2 ports
MARKETING_PORT=3000
ADMIN_PORT=3001
OPERATOR_PORT=3002

# PostgreSQL — Supabase: use **Transaction pooler** port 6543 (not session 5432)
# Example: postgresql://postgres.xxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require
DATABASE_POOL_MAX=3

# Auth — openssl rand -hex 32
AUTH_SECRET=CHANGE_ME_64_CHAR_HEX
NEXTAUTH_SECRET=CHANGE_ME_64_CHAR_HEX
SUPER_ADMIN_SECURITY_CODE=CYBER-LINK-2026

# Syslog ingest (MikroTik + listener use this)
INGEST_SECRET=CHANGE_ME_STRONG_INGEST_SECRET
CRON_SECRET=CHANGE_ME_CRON_SECRET
DEFAULT_TENANT_SCHEMA=tenant_001

# Syslog listener (PM2: isp-syslog-listener)
SYSLOG_UDP_PORT=514
SOCKET_PORT=3001
SYSLOG_FILE=/var/log/mikrotik/isp-syslog.log
SYSLOG_TAIL_FILE=true

# Optional
IMGBB_API_KEY=

BTRC_ISP_LICENSE=ISP-BD-CYBER-2024
BTRC_ISP_NAME="Cyber Link Communication"
BTRC_CONTACT_EMAIL=admin@cyberlink.com
