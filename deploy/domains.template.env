# =============================================================================
# ৩টা Domain — পরে fill করুন, তারপর nginx + .env.production.local update
# Copy: cp deploy/domains.template.env deploy/domains.env
# =============================================================================

# SECTION 1 — Marketing (port 3000)
MARKETING_DOMAIN=www.YOUR-DOMAIN.com
MARKETING_DOMAIN_ROOT=YOUR-DOMAIN.com

# SECTION 2 — Super Admin (port 3001)
ADMIN_DOMAIN=admin.YOUR-DOMAIN.com

# SECTION 3 — Operator + API (port 3002)
OPERATOR_DOMAIN=app.YOUR-DOMAIN.com

# VPS IP (change if different)
VPS_IP=160.187.175.30

# Example (Cyber Link — uncomment when ready):
# MARKETING_DOMAIN=www.cyberlink.com
# MARKETING_DOMAIN_ROOT=cyberlink.com
# ADMIN_DOMAIN=admin.cyberlink.com
# OPERATOR_DOMAIN=app.cyberlink.com
