{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@isp/core": ["./packages/core/src/index.ts"],
      "@isp/core/*": ["./packages/core/src/*"],
      "@isp/auth": ["./packages/auth/src/index.ts"],
      "@isp/auth/*": ["./packages/auth/src/*"],
      "@isp/ui": ["./packages/ui/src/index.ts"],
      "@isp/ui/*": ["./packages/ui/src/*"],
      "@isp/features/*": ["./packages/features/src/*"]
    }
  }
}
